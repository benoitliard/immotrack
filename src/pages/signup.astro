---
import AuthLayout from '~/layouts/AuthLayout.astro';
import SignupForm from '~/components/auth/SignupForm.astro';
---

<AuthLayout title="Créer un compte">
  <div class="mb-6">
    <h1 class="text-2xl font-semibold tracking-tight text-slate-900">Creer un compte</h1>
    <p class="mt-1 text-sm text-slate-500">Rejoignez ImmoTrack en quelques secondes</p>
  </div>
  <SignupForm />
</AuthLayout>
