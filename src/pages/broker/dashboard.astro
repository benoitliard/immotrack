---
import BrokerLayout from '~/layouts/BrokerLayout.astro';
import Badge from '~/components/ui/Badge.astro';
import Button from '~/components/ui/Button.astro';
import { db } from '~/lib/db';
import { transactions, transactionStages, properties, activityLog, transactionParticipants, user as userTable } from '~/db/schema';
import { eq, count, desc } from 'drizzle-orm';
import { typeLabels, statusLabels, typeBadgeVariant, statusBadgeVariant, formatDate } from '~/lib/labels';

const currentUser = Astro.locals.user!;
const firstName = currentUser.name?.split(' ')[0] ?? 'Courtier';

// ── Stats ────────────────────────────────────────────────────────────────────
const allTransactions = await db.select().from(transactions)
  .where(eq(transactions.brokerId, currentUser.id));

const activeCount = allTransactions.filter(t => t.status === 'active').length;
const onHoldCount = allTransactions.filter(t => t.status === 'on_hold').length;

const now = new Date();
const startOfMonth = new Date(now.getFullYear(), now.getMonth(), 1);
const completedThisMonth = allTransactions.filter(
  t => t.status === 'completed' && t.updatedAt && new Date(t.updatedAt) >= startOfMonth
).length;

// ── Recent transactions with stages + property ──────────────────────────────
const recentTransactions = await db.select({
  id: transactions.id,
  title: transactions.title,
  type: transactions.type,
  status: transactions.status,
  currentStageOrder: transactions.currentStageOrder,
  closingDate: transactions.closingDate,
  createdAt: transactions.createdAt,
  propertyAddress: properties.address,
  propertyCity: properties.city,
})
  .from(transactions)
  .leftJoin(properties, eq(transactions.propertyId, properties.id))
  .where(eq(transactions.brokerId, currentUser.id))
  .orderBy(desc(transactions.updatedAt))
  .limit(5);

// Get stage info for each transaction
const txWithStages = await Promise.all(recentTransactions.map(async (tx) => {
  const stages = await db.select().from(transactionStages)
    .where(eq(transactionStages.transactionId, tx.id))
    .orderBy(transactionStages.orderIndex);

  const currentStage = stages.find(s => s.status === 'current');
  const totalStages = stages.length;
  const completedStages = stages.filter(s => s.status === 'completed').length;
  const progress = totalStages > 0 ? Math.round((completedStages / totalStages) * 100) : 0;

  const participantCount = await db.select({ count: count() })
    .from(transactionParticipants)
    .where(eq(transactionParticipants.transactionId, tx.id));

  return {
    ...tx,
    currentStageName: currentStage?.name ?? (tx.status === 'completed' ? 'Terminee' : '—'),
    totalStages,
    completedStages,
    progress,
    participantCount: participantCount[0]?.count ?? 0,
  };
}));

// ── Recent activity ─────────────────────────────────────────────────────────
const recentActivity = await db.select({
  id: activityLog.id,
  action: activityLog.action,
  metadata: activityLog.metadata,
  createdAt: activityLog.createdAt,
  transactionId: activityLog.transactionId,
  userName: userTable.name,
})
  .from(activityLog)
  .leftJoin(userTable, eq(activityLog.userId, userTable.id))
  .innerJoin(transactions, eq(activityLog.transactionId, transactions.id))
  .where(eq(transactions.brokerId, currentUser.id))
  .orderBy(desc(activityLog.createdAt))
  .limit(8);

const hasTransactions = allTransactions.length > 0;
---

<BrokerLayout title="Tableau de bord">
  <!-- Page header -->
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-2xl font-semibold tracking-tight text-slate-900">Bienvenue, {firstName}</h1>
      <p class="text-slate-500 mt-1">Voici un apercu de vos transactions en cours.</p>
    </div>
    {hasTransactions && (
      <Button href="/broker/transactions/new" variant="primary" size="md">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
        </svg>
        Nouvelle transaction
      </Button>
    )}
  </div>

  <!-- Stats cards -->
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 mb-8">
    <div class="bg-white rounded-xl border border-slate-200 p-6">
      <div class="flex items-center justify-between mb-4">
        <span class="text-sm font-medium text-slate-500">Transactions actives</span>
        <div class="w-8 h-8 bg-violet-50 rounded-lg flex items-center justify-center">
          <svg class="w-4 h-4 text-violet-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
          </svg>
        </div>
      </div>
      <p class="text-3xl font-semibold text-slate-900">{activeCount}</p>
      <p class="text-xs text-slate-400 mt-1">en cours</p>
    </div>

    <div class="bg-white rounded-xl border border-slate-200 p-6">
      <div class="flex items-center justify-between mb-4">
        <span class="text-sm font-medium text-slate-500">En attente</span>
        <div class="w-8 h-8 bg-amber-50 rounded-lg flex items-center justify-center">
          <svg class="w-4 h-4 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
      </div>
      <p class="text-3xl font-semibold text-slate-900">{onHoldCount}</p>
      <p class="text-xs text-slate-400 mt-1">en attente d'action</p>
    </div>

    <div class="bg-white rounded-xl border border-slate-200 p-6">
      <div class="flex items-center justify-between mb-4">
        <span class="text-sm font-medium text-slate-500">Completees ce mois</span>
        <div class="w-8 h-8 bg-emerald-50 rounded-lg flex items-center justify-center">
          <svg class="w-4 h-4 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
      </div>
      <p class="text-3xl font-semibold text-slate-900">{completedThisMonth}</p>
      <p class="text-xs text-slate-400 mt-1">ce mois-ci</p>
    </div>
  </div>

  {hasTransactions ? (
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <!-- Recent transactions -->
      <div class="lg:col-span-2">
        <div class="bg-white rounded-xl border border-slate-200">
          <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between">
            <h2 class="text-sm font-semibold text-slate-900">Transactions recentes</h2>
            <a href="/broker/transactions" class="text-xs font-medium text-violet-600 hover:text-violet-700 transition-colors">
              Voir tout
            </a>
          </div>
          <div class="divide-y divide-slate-100">
            {txWithStages.map((tx) => (
              <a href={`/broker/transactions/${tx.id}`} class="flex items-center gap-4 px-6 py-4 hover:bg-slate-50 transition-colors">
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 mb-1">
                    <p class="text-sm font-medium text-slate-900 truncate">{tx.title}</p>
                    <Badge variant={typeBadgeVariant[tx.type] ?? 'neutral'} size="sm">{typeLabels[tx.type]}</Badge>
                  </div>
                  <div class="flex items-center gap-3 text-xs text-slate-500">
                    {tx.propertyCity && <span>{tx.propertyCity}</span>}
                    <span class="text-slate-300">·</span>
                    <span>{tx.currentStageName}</span>
                    {tx.participantCount > 0 && (
                      <>
                        <span class="text-slate-300">·</span>
                        <span>{tx.participantCount} participant{tx.participantCount > 1 ? 's' : ''}</span>
                      </>
                    )}
                  </div>
                </div>
                <div class="flex items-center gap-3 flex-shrink-0">
                  <!-- Progress bar -->
                  <div class="w-24 hidden sm:block">
                    <div class="flex items-center justify-between text-xs text-slate-400 mb-1">
                      <span>{tx.completedStages}/{tx.totalStages}</span>
                      <span>{tx.progress}%</span>
                    </div>
                    <div class="w-full h-1.5 bg-slate-100 rounded-full overflow-hidden">
                      <div
                        class:list={[
                          "h-full rounded-full transition-all duration-500",
                          tx.status === 'completed' ? 'bg-emerald-500' : 'bg-violet-500'
                        ]}
                        style={`width: ${tx.progress}%`}
                      />
                    </div>
                  </div>
                  <Badge variant={statusBadgeVariant[tx.status ?? 'active'] ?? 'neutral'} size="sm">{statusLabels[tx.status ?? 'active']}</Badge>
                  <svg class="w-4 h-4 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                  </svg>
                </div>
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- Activity feed -->
      <div class="lg:col-span-1">
        <div class="bg-white rounded-xl border border-slate-200">
          <div class="px-6 py-4 border-b border-slate-100">
            <h2 class="text-sm font-semibold text-slate-900">Activite recente</h2>
          </div>
          <div class="px-6 py-3 divide-y divide-slate-50">
            {recentActivity.length > 0 ? (
              recentActivity.map((activity) => {
                const meta = activity.metadata ? JSON.parse(activity.metadata) : {};
                return (
                  <div class="py-3 first:pt-0 last:pb-0">
                    <div class="flex items-start gap-3">
                      <div class="mt-0.5 w-6 h-6 bg-slate-100 rounded-full flex items-center justify-center flex-shrink-0">
                        <svg class="w-3 h-3 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
                        </svg>
                      </div>
                      <div class="min-w-0 flex-1">
                        <p class="text-xs text-slate-700">
                          <span class="font-medium">{activity.userName ?? 'Systeme'}</span>
                          {' — '}
                          {activity.action}
                        </p>
                        <p class="text-xs text-slate-400 mt-0.5">
                          {formatDate(activity.createdAt)}
                        </p>
                      </div>
                    </div>
                  </div>
                );
              })
            ) : (
              <p class="text-sm text-slate-400 py-4 text-center">Aucune activite recente</p>
            )}
          </div>
        </div>
      </div>
    </div>
  ) : (
    <!-- Empty state -->
    <div class="bg-white rounded-xl border border-slate-200">
      <div class="flex flex-col items-center justify-center py-20 px-8 text-center">
        <div class="w-14 h-14 bg-slate-50 rounded-xl flex items-center justify-center mb-5 ring-1 ring-inset ring-slate-200">
          <svg class="w-7 h-7 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 13h6m-3-3v6m-9 1V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z" />
          </svg>
        </div>
        <h2 class="text-lg font-semibold text-slate-900 mb-2">Aucune transaction en cours</h2>
        <p class="text-slate-500 text-sm max-w-sm mb-6">
          Creez votre premiere transaction pour commencer a suivre l'avancement avec vos clients.
        </p>
        <Button href="/broker/transactions/new" variant="primary" size="md">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
          </svg>
          Creer une transaction
        </Button>
      </div>
    </div>
  )}
</BrokerLayout>
