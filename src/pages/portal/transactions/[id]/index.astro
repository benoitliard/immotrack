---
import PortalLayout from '~/layouts/PortalLayout.astro';
import Badge from '~/components/ui/Badge.astro';
import { db } from '~/lib/db';
import { transactions, transactionParticipants, transactionStages, properties, documents } from '~/db/schema';
import { eq, and } from 'drizzle-orm';

const { id } = Astro.params;
const user = Astro.locals.user!;

// Verify user is a participant in this transaction
const [participation] = await db
  .select()
  .from(transactionParticipants)
  .where(and(
    eq(transactionParticipants.transactionId, id!),
    eq(transactionParticipants.userId, user.id)
  ));

if (!participation) {
  return Astro.redirect('/portal');
}

// Fetch transaction details
const [tx] = await db
  .select()
  .from(transactions)
  .where(eq(transactions.id, id!));

if (!tx) {
  return Astro.redirect('/portal');
}

// Fetch related data in parallel
const [property, stages, txDocuments] = await Promise.all([
  tx.propertyId
    ? db.select().from(properties).where(eq(properties.id, tx.propertyId)).then(r => r[0] ?? null)
    : Promise.resolve(null),
  db.select().from(transactionStages).where(eq(transactionStages.transactionId, tx.id)).orderBy(transactionStages.orderIndex),
  db.select().from(documents).where(eq(documents.transactionId, tx.id)).orderBy(documents.createdAt),
]);

const typeLabels: Record<string, string> = {
  purchase: 'Achat',
  sale: 'Vente',
  rental: 'Location',
};

const typeBadgeVariant: Record<string, 'info' | 'success' | 'warning'> = {
  purchase: 'info',
  sale: 'success',
  rental: 'warning',
};

const statusLabels: Record<string, string> = {
  active: 'Active',
  completed: 'Completee',
  cancelled: 'Annulee',
  on_hold: 'En pause',
};

const completedStages = stages.filter(s => s.status === 'completed').length;
const totalStages = stages.length;
const progressPercent = totalStages > 0 ? Math.round((completedStages / totalStages) * 100) : 0;

function formatDate(date: Date | null | undefined): string {
  if (!date) return '--';
  return new Intl.DateTimeFormat('fr-CA', { dateStyle: 'medium' }).format(new Date(date));
}

function formatFileSize(bytes: number | null | undefined): string {
  if (!bytes) return '';
  if (bytes < 1024) return `${bytes} o`;
  if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(0)} Ko`;
  return `${(bytes / (1024 * 1024)).toFixed(1)} Mo`;
}
---

<PortalLayout title={tx.title}>
  <!-- Back link -->
  <div class="flex items-center gap-2 text-sm text-slate-500 mb-6">
    <a href="/portal" class="hover:text-slate-700 transition-colors">Mes transactions</a>
    <svg class="w-4 h-4 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
    </svg>
    <span class="text-slate-900 font-medium truncate max-w-xs">{tx.title}</span>
  </div>

  <!-- Transaction header -->
  <div class="bg-white rounded-xl border border-slate-200 p-6 mb-6">
    <div class="flex flex-wrap items-center gap-2 mb-3">
      <h1 class="text-xl font-semibold tracking-tight text-slate-900">{tx.title}</h1>
      <Badge variant={typeBadgeVariant[tx.type] ?? 'neutral'}>{typeLabels[tx.type] ?? tx.type}</Badge>
      <Badge variant={
        tx.status === 'active' ? 'success' :
        tx.status === 'completed' ? 'neutral' :
        tx.status === 'cancelled' ? 'danger' :
        'warning'
      }>
        {statusLabels[tx.status ?? 'active']}
      </Badge>
    </div>

    <!-- Overall progress -->
    <div class="mt-4">
      <div class="flex items-center justify-between mb-2">
        <span class="text-sm font-medium text-slate-700">Progression globale</span>
        <span class="text-sm font-semibold text-violet-600">{progressPercent}%</span>
      </div>
      <div class="w-full bg-slate-100 rounded-full h-2">
        <div
          class={`h-2 rounded-full transition-all duration-700 ${progressPercent === 100 ? 'bg-emerald-500' : 'bg-violet-500'}`}
          style={`width: ${progressPercent}%`}
        ></div>
      </div>
      <p class="text-xs text-slate-400 mt-1.5">
        {completedStages} etape{completedStages > 1 ? 's' : ''} completee{completedStages > 1 ? 's' : ''} sur {totalStages}
      </p>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Left: Timeline + Documents -->
    <div class="lg:col-span-2 space-y-6">

      <!-- Stage timeline -->
      <div class="bg-white rounded-xl border border-slate-200 p-6">
        <h2 class="font-semibold text-slate-900 mb-5">Etapes de votre transaction</h2>
        {stages.length === 0 ? (
          <p class="text-sm text-slate-400 italic">Les etapes seront affichees une fois la transaction configuree.</p>
        ) : (
          <ol class="relative">
            {stages.map((stage, idx) => (
              <li class={`relative pl-8 ${idx < stages.length - 1 ? 'pb-6' : ''}`}>
                {idx < stages.length - 1 && (
                  <div class={`absolute left-3 top-5 w-0.5 bottom-0 ${stage.status === 'completed' ? 'bg-emerald-300' : 'bg-slate-200'}`}></div>
                )}

                <div class={`absolute left-0 w-6 h-6 rounded-full flex items-center justify-center border-2 ${
                  stage.status === 'completed'
                    ? 'bg-emerald-500 border-emerald-500'
                    : stage.status === 'current'
                    ? 'bg-white border-violet-500 ring-4 ring-violet-100'
                    : 'bg-white border-slate-200'
                }`}>
                  {stage.status === 'completed' && (
                    <svg class="w-3.5 h-3.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                  )}
                  {stage.status === 'current' && (
                    <span class="w-2 h-2 bg-violet-500 rounded-full animate-pulse"></span>
                  )}
                </div>

                <div>
                  <div class="flex flex-wrap items-center gap-2">
                    <span class={`text-sm font-semibold ${
                      stage.status === 'current' ? 'text-slate-900' :
                      stage.status === 'completed' ? 'text-slate-700' :
                      'text-slate-400'
                    }`}>
                      {stage.name}
                    </span>
                    {stage.status === 'current' && (
                      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-violet-50 text-violet-700 ring-1 ring-inset ring-violet-600/20">
                        Etape en cours
                      </span>
                    )}
                  </div>
                  {stage.description && (
                    <p class={`text-xs mt-0.5 ${stage.status === 'pending' ? 'text-slate-300' : 'text-slate-500'}`}>
                      {stage.description}
                    </p>
                  )}
                  {stage.completedAt && (
                    <p class="text-xs text-slate-400 mt-0.5">Completee le {formatDate(stage.completedAt)}</p>
                  )}
                </div>
              </li>
            ))}
          </ol>
        )}
      </div>

      <!-- Documents -->
      <div class="bg-white rounded-xl border border-slate-200 p-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="font-semibold text-slate-900">Documents</h2>
          <a
            href={`/portal/transactions/${tx.id}/chat`}
            class="text-xs font-medium text-violet-600 hover:text-violet-700 transition-colors flex items-center gap-1"
          >
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
            </svg>
            Messagerie
          </a>
        </div>

        {txDocuments.length === 0 ? (
          <div class="text-center py-8">
            <svg class="w-10 h-10 text-slate-200 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            <p class="text-sm text-slate-400">Aucun document partage pour l'instant.</p>
          </div>
        ) : (
          <ul class="space-y-2">
            {txDocuments.map((doc) => (
              <li class="flex items-center gap-3 p-3 rounded-lg bg-slate-50 hover:bg-violet-50 transition-all duration-200 group">
                <div class="w-8 h-8 bg-white rounded-lg border border-slate-200 flex items-center justify-center flex-shrink-0">
                  <svg class="w-4 h-4 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                  </svg>
                </div>
                <div class="flex-1 min-w-0">
                  <p class="text-sm font-medium text-slate-900 truncate">{doc.name}</p>
                  <p class="text-xs text-slate-400">
                    {formatDate(doc.createdAt)}
                    {doc.fileSize ? ` · ${formatFileSize(doc.fileSize)}` : ''}
                  </p>
                </div>
                {doc.filePath && (
                  <a
                    href={doc.filePath}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-violet-600 hover:text-violet-700 opacity-0 group-hover:opacity-100 transition-opacity flex-shrink-0"
                    title="Telecharger"
                  >
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                    </svg>
                  </a>
                )}
              </li>
            ))}
          </ul>
        )}
      </div>
    </div>

    <!-- Right: Property + Chat link -->
    <div class="space-y-6">
      {property && (
        <div class="bg-white rounded-xl border border-slate-200 p-5">
          <div class="flex items-start justify-between mb-4">
            <h2 class="font-semibold text-slate-900 text-sm">Propriete</h2>
          </div>
          <div class="space-y-3">
            <div>
              <p class="text-xs text-slate-400 uppercase tracking-wider font-medium mb-0.5">Adresse</p>
              <p class="text-sm text-slate-900 font-medium">{property.address}</p>
              <p class="text-sm text-slate-500">{property.city}, {property.province}</p>
            </div>
            <div>
              <p class="text-xs text-slate-400 uppercase tracking-wider font-medium mb-0.5">Type</p>
              <p class="text-sm text-slate-900">{property.propertyType}</p>
            </div>
            {(property.bedrooms || property.bathrooms) && (
              <div>
                <p class="text-xs text-slate-400 uppercase tracking-wider font-medium mb-0.5">Configuration</p>
                <p class="text-sm text-slate-900">
                  {[
                    property.bedrooms ? `${property.bedrooms} chambres` : '',
                    property.bathrooms ? `${property.bathrooms} s.d.b.` : '',
                  ].filter(Boolean).join(' · ')}
                </p>
              </div>
            )}
            {property.listingPrice && (
              <div>
                <p class="text-xs text-slate-400 uppercase tracking-wider font-medium mb-0.5">Prix demande</p>
                <p class="text-sm font-bold text-slate-900">
                  {new Intl.NumberFormat('fr-CA', { style: 'currency', currency: 'CAD', maximumFractionDigits: 0 }).format(property.listingPrice)}
                </p>
              </div>
            )}
          </div>
          <a
            href={`/portal/transactions/${tx.id}/property`}
            class="mt-4 flex items-center justify-center gap-2 w-full px-4 py-2.5 rounded-lg border border-slate-200 bg-white text-sm font-medium text-slate-700 hover:bg-slate-50 active:scale-[0.98] transition-all duration-200"
          >
            <svg class="w-4 h-4 text-violet-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
            </svg>
            Voir la fiche de la propriete
          </a>
        </div>
      )}

      <!-- Chat CTA -->
      <div class="bg-white rounded-xl border border-slate-200 p-5">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-9 h-9 bg-violet-50 rounded-lg flex items-center justify-center ring-1 ring-inset ring-violet-600/10">
            <svg class="w-5 h-5 text-violet-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
            </svg>
          </div>
          <div>
            <p class="font-semibold text-slate-900 text-sm">Messagerie</p>
            <p class="text-xs text-slate-500">Echangez avec votre courtier</p>
          </div>
        </div>
        <a
          href={`/portal/transactions/${tx.id}/chat`}
          class="block w-full text-center px-4 py-2.5 rounded-lg bg-violet-600 text-white text-sm font-medium hover:bg-violet-700 active:scale-[0.98] transition-all duration-200 shadow-sm"
        >
          Contacter mon courtier
        </a>
      </div>
    </div>
  </div>
</PortalLayout>
