---
import PortalLayout from '~/layouts/PortalLayout.astro';
import Badge from '~/components/ui/Badge.astro';
import { db } from '~/lib/db';
import { transactions, transactionParticipants, transactionStages, properties } from '~/db/schema';
import { eq, inArray, count } from 'drizzle-orm';

const user = Astro.locals.user!;

// Fetch transaction IDs where current user is a participant
const participantRows = await db
  .select({ transactionId: transactionParticipants.transactionId })
  .from(transactionParticipants)
  .where(eq(transactionParticipants.userId, user.id));

const txIds = participantRows.map(p => p.transactionId);

let portalTransactions: Array<{
  id: string;
  title: string;
  type: string;
  status: string | null;
  currentStageOrder: number | null;
  propertyAddress: string | null;
  propertyCity: string | null;
  totalStages: number;
}> = [];

if (txIds.length > 0) {
  // Fetch transactions with property info
  const txData = await db
    .select({
      id: transactions.id,
      title: transactions.title,
      type: transactions.type,
      status: transactions.status,
      currentStageOrder: transactions.currentStageOrder,
      propertyAddress: properties.address,
      propertyCity: properties.city,
    })
    .from(transactions)
    .leftJoin(properties, eq(transactions.propertyId, properties.id))
    .where(inArray(transactions.id, txIds));

  // Get stage counts per transaction
  const stageCounts = await db
    .select({
      transactionId: transactionStages.transactionId,
      total: count(transactionStages.id),
    })
    .from(transactionStages)
    .where(inArray(transactionStages.transactionId, txIds))
    .groupBy(transactionStages.transactionId);

  const stageCountMap = new Map(stageCounts.map(s => [s.transactionId, Number(s.total)]));

  portalTransactions = txData.map(tx => ({
    ...tx,
    status: tx.status ?? null,
    totalStages: stageCountMap.get(tx.id) ?? 0,
  }));
}

const typeLabels: Record<string, string> = {
  purchase: 'Achat',
  sale: 'Vente',
  rental: 'Location',
};

const typeBadgeVariant: Record<string, 'info' | 'success' | 'warning'> = {
  purchase: 'info',
  sale: 'success',
  rental: 'warning',
};

const statusLabels: Record<string, string> = {
  active: 'Active',
  completed: 'Completee',
  cancelled: 'Annulee',
  on_hold: 'En pause',
};

function getProgressPercent(current: number | null, total: number): number {
  if (!current || total === 0) return 0;
  return Math.round(((current - 1) / total) * 100);
}
---

<PortalLayout title="Mes transactions">
  <div class="mb-8">
    <h1 class="text-2xl font-semibold tracking-tight text-slate-900">Mes transactions</h1>
    <p class="text-slate-500 mt-1">
      {portalTransactions.length === 0
        ? 'Aucune transaction en cours'
        : `${portalTransactions.length} transaction${portalTransactions.length > 1 ? 's' : ''} en cours`}
    </p>
  </div>

  {portalTransactions.length === 0 ? (
    <div class="bg-white rounded-xl border border-slate-200">
      <div class="flex flex-col items-center justify-center py-20 px-8 text-center">
        <div class="w-14 h-14 bg-slate-50 rounded-xl flex items-center justify-center mb-5 ring-1 ring-inset ring-slate-200">
          <svg class="w-7 h-7 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
          </svg>
        </div>
        <h2 class="text-lg font-semibold text-slate-900 mb-2">Aucune transaction</h2>
        <p class="text-slate-500 text-sm max-w-sm">
          Votre courtier vous invitera a rejoindre une transaction. Vous recevrez une notification par courriel.
        </p>
      </div>
    </div>
  ) : (
    <div class="space-y-4">
      {portalTransactions.map((tx) => {
        const progress = getProgressPercent(tx.currentStageOrder, tx.totalStages);
        return (
          <a
            href={`/portal/transactions/${tx.id}`}
            class="block bg-white rounded-xl border border-slate-200 hover:border-slate-300 transition-all duration-200 group"
          >
            <div class="p-5">
              <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-3 mb-4">
                <div>
                  <div class="flex flex-wrap items-center gap-2 mb-1">
                    <h3 class="font-semibold text-slate-900 group-hover:text-violet-700 transition-colors">
                      {tx.title}
                    </h3>
                    <Badge variant={typeBadgeVariant[tx.type] ?? 'neutral'} size="sm">
                      {typeLabels[tx.type] ?? tx.type}
                    </Badge>
                  </div>
                  {(tx.propertyAddress || tx.propertyCity) && (
                    <p class="text-sm text-slate-500 flex items-center gap-1">
                      <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                      </svg>
                      {[tx.propertyAddress, tx.propertyCity].filter(Boolean).join(', ')}
                    </p>
                  )}
                </div>
                <div class="flex items-center gap-2 flex-shrink-0">
                  <Badge variant={
                    tx.status === 'active' ? 'success' :
                    tx.status === 'completed' ? 'neutral' :
                    tx.status === 'cancelled' ? 'danger' :
                    'warning'
                  } size="sm">
                    {statusLabels[tx.status ?? 'active'] ?? tx.status}
                  </Badge>
                  <svg class="w-4 h-4 text-slate-300 group-hover:text-violet-500 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                  </svg>
                </div>
              </div>

              <!-- Progress bar -->
              <div>
                <div class="flex items-center justify-between mb-1.5">
                  <span class="text-xs text-slate-500">Etape {tx.currentStageOrder ?? 1} sur {tx.totalStages || '?'}</span>
                  <span class="text-xs font-medium text-violet-600">{progress}%</span>
                </div>
                <div class="w-full bg-slate-100 rounded-full h-1.5">
                  <div
                    class={`h-1.5 rounded-full transition-all duration-500 ${progress === 100 ? 'bg-emerald-500' : 'bg-violet-500'}`}
                    style={`width: ${progress}%`}
                  ></div>
                </div>
              </div>
            </div>
          </a>
        );
      })}
    </div>
  )}
</PortalLayout>
