---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { db } from '~/lib/db';
import { transactions, user as userTable } from '~/db/schema';
import { eq, count } from 'drizzle-orm';

const user = Astro.locals.user as (typeof Astro.locals.user & { role?: string }) | null;

// Admin check (middleware handles redirect, but double-check here)
if (!user || user.role !== 'admin') {
  return Astro.redirect('/login');
}

// Basic stats
const [userCount, txCount] = await Promise.all([
  db.select({ total: count(userTable.id) }).from(userTable).then(r => r[0]?.total ?? 0),
  db.select({ total: count(transactions.id) }).from(transactions).then(r => r[0]?.total ?? 0),
]);

const activeTxCount = await db
  .select({ total: count(transactions.id) })
  .from(transactions)
  .where(eq(transactions.status, 'active'))
  .then(r => r[0]?.total ?? 0);
---

<BaseLayout title="Administration">
  <div class="min-h-screen bg-slate-50">
    <!-- Header -->
    <header class="bg-white border-b border-slate-200">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <div class="flex items-center gap-3">
            <span class="font-bold tracking-tight text-slate-900">Immo<span class="text-violet-600">Track</span></span>
            <span class="px-2 py-0.5 rounded-md bg-violet-50 text-violet-700 text-xs font-semibold uppercase tracking-wider ring-1 ring-inset ring-violet-600/20">Admin</span>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-sm text-slate-600">{user.name}</span>
            <button
              id="logout-btn"
              type="button"
              class="text-sm text-slate-500 hover:text-slate-700 transition-colors"
            >
              Deconnexion
            </button>
          </div>
        </div>
      </div>
    </header>

    <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <!-- Page title -->
      <div class="mb-8">
        <h1 class="text-2xl font-semibold tracking-tight text-slate-900">Administration ImmoTrack</h1>
        <p class="text-slate-500 mt-1">Tableau de bord d'administration de la plateforme.</p>
      </div>

      <!-- Stats -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 mb-10">
        <div class="bg-white rounded-xl border border-slate-200 p-6">
          <div class="flex items-center justify-between mb-4">
            <span class="text-sm font-medium text-slate-500">Utilisateurs total</span>
            <div class="w-8 h-8 bg-violet-50 rounded-lg flex items-center justify-center">
              <svg class="w-4 h-4 text-violet-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
          </div>
          <p class="text-3xl font-semibold text-slate-900">{userCount}</p>
          <p class="text-xs text-slate-400 mt-1">inscrits</p>
        </div>

        <div class="bg-white rounded-xl border border-slate-200 p-6">
          <div class="flex items-center justify-between mb-4">
            <span class="text-sm font-medium text-slate-500">Transactions total</span>
            <div class="w-8 h-8 bg-violet-50 rounded-lg flex items-center justify-center">
              <svg class="w-4 h-4 text-violet-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
              </svg>
            </div>
          </div>
          <p class="text-3xl font-semibold text-slate-900">{txCount}</p>
          <p class="text-xs text-slate-400 mt-1">creees</p>
        </div>

        <div class="bg-white rounded-xl border border-slate-200 p-6">
          <div class="flex items-center justify-between mb-4">
            <span class="text-sm font-medium text-slate-500">Transactions actives</span>
            <div class="w-8 h-8 bg-emerald-50 rounded-lg flex items-center justify-center">
              <svg class="w-4 h-4 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
          </div>
          <p class="text-3xl font-semibold text-slate-900">{activeTxCount}</p>
          <p class="text-xs text-slate-400 mt-1">en cours</p>
        </div>
      </div>

      <!-- Quick links -->
      <div class="bg-white rounded-xl border border-slate-200 p-6">
        <h2 class="font-semibold text-slate-900 mb-4">Navigation rapide</h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
          <a href="/broker/dashboard" class="flex items-center gap-3 p-3 rounded-lg bg-slate-50 hover:bg-violet-50 hover:text-violet-700 transition-all duration-200 text-sm font-medium text-slate-700">
            <svg class="w-4 h-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
            Espace courtier
          </a>
          <a href="/portal" class="flex items-center gap-3 p-3 rounded-lg bg-slate-50 hover:bg-violet-50 hover:text-violet-700 transition-all duration-200 text-sm font-medium text-slate-700">
            <svg class="w-4 h-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
            Portail client
          </a>
          <a href="/" class="flex items-center gap-3 p-3 rounded-lg bg-slate-50 hover:bg-violet-50 hover:text-violet-700 transition-all duration-200 text-sm font-medium text-slate-700">
            <svg class="w-4 h-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Page d'accueil
          </a>
        </div>
      </div>
    </main>
  </div>
</BaseLayout>

<script>
  import { authClient } from '~/lib/auth-client';

  document.getElementById('logout-btn')?.addEventListener('click', async () => {
    await authClient.signOut();
    window.location.href = '/login';
  });
</script>
